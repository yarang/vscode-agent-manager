{
  "name": "agent-manager",
  "displayName": "Agent Manager for relay-plugin",
  "description": "VS Code GUI for relay-plugin agent configuration, team building, and management",
  "version": "0.1.0",
  "publisher": "relay-plugin",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.svg",
  "contributes": {
    "commands": [
      {
        "command": "agentManager.openDashboard",
        "title": "Agent Manager: Open Dashboard",
        "icon": "$(home)"
      },
      {
        "command": "agentManager.createExpert",
        "title": "Agent Manager: Create Expert",
        "icon": "$(add)"
      },
      {
        "command": "agentManager.openExpertManager",
        "title": "Agent Manager: Open Expert Manager"
      },
      {
        "command": "agentManager.buildTeam",
        "title": "Agent Manager: Build Team",
        "icon": "$(group-by-ref-type)"
      },
      {
        "command": "agentManager.editAgent",
        "title": "Agent Manager: Edit Agent Definition",
        "icon": "$(edit)"
      },
      {
        "command": "agentManager.openSettings",
        "title": "Agent Manager: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "agentManager.refreshTree",
        "title": "Agent Manager: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentManager.createExpertFromTree",
        "title": "Create Expert",
        "icon": "$(add)"
      },
      {
        "command": "agentManager.buildTeamFromTree",
        "title": "Build Team",
        "icon": "$(group-by-ref-type)"
      },
      {
        "command": "agentManager.refreshFromTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentManager.openExpert",
        "title": "Open Expert",
        "icon": "$(go-to-file)"
      },
      {
        "command": "agentManager.viewTeamDetails",
        "title": "View Team Details",
        "icon": "$(graph)"
      },
      {
        "command": "agentManager.viewTeamDiagram",
        "title": "View Team Diagram",
        "icon": "$(graph)"
      },
      {
        "command": "agentManager.viewExpertDiagram",
        "title": "View Expert Mind Map",
        "icon": "$(graph-scatter)"
      },
      {
        "command": "agentManager.deleteExpert",
        "title": "Delete Expert",
        "icon": "$(trash)"
      },
      {
        "command": "agentManager.deleteTeam",
        "title": "Delete Team",
        "icon": "$(trash)"
      },
      {
        "command": "agentManager.duplicateExpert",
        "title": "Duplicate Expert",
        "icon": "$(copy)"
      },
      {
        "command": "agentManager.openRelayFolder",
        "title": "Open Relay Folder",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-manager",
          "title": "Agent Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-manager": [
        {
          "id": "agentManager.treeView",
          "name": "Teams & Experts"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agentManager.openDashboard",
          "when": "view == agentManager.treeView",
          "group": "navigation@1"
        },
        {
          "command": "agentManager.refreshTree",
          "when": "view == agentManager.treeView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "agentManager.createExpertFromTree",
          "when": "view == agentManager.treeView && viewItem == experts",
          "group": "inline@1"
        },
        {
          "command": "agentManager.buildTeamFromTree",
          "when": "view == agentManager.treeView && viewItem == teams",
          "group": "inline@1"
        },
        {
          "command": "agentManager.refreshFromTree",
          "when": "view == agentManager.treeView",
          "group": "inline@2"
        },
        {
          "command": "agentManager.openExpert",
          "when": "view == agentManager.treeView && viewItem == expert",
          "group": "manage@1"
        },
        {
          "command": "agentManager.viewExpertDiagram",
          "when": "view == agentManager.treeView && viewItem == expert",
          "group": "visualize@1"
        },
        {
          "command": "agentManager.duplicateExpert",
          "when": "view == agentManager.treeView && viewItem == expert",
          "group": "manage@2"
        },
        {
          "command": "agentManager.deleteExpert",
          "when": "view == agentManager.treeView && viewItem == expert",
          "group": "manage@3"
        },
        {
          "command": "agentManager.viewTeamDetails",
          "when": "view == agentManager.treeView && viewItem == team",
          "group": "visualize@1"
        },
        {
          "command": "agentManager.deleteTeam",
          "when": "view == agentManager.treeView && viewItem == team",
          "group": "manage@1"
        },
        {
          "command": "agentManager.openRelayFolder",
          "when": "view == agentManager.treeView && viewItem == config",
          "group": "manage@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "agentManager.openDashboard",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "npm run compile && node ./node_modules/vscode/bin/test",
    "test:unit": "npm run compile && mocha test/unit/**/*.test.js",
    "test:e2e": "npm run compile && node ./node_modules/vscode/bin/test",
    "test:coverage": "npm run compile && nyc mocha test/unit/**/*.test.js",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.84.0",
    "@vscode/test-electron": "^2.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "glob": "^10.3.0",
    "mocha": "^10.3.0",
    "nyc": "^15.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "yaml": "^2.4.5",
    "zod": "^3.22.4"
  }
}
